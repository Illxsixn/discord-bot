# Discord Bot – Umgebungsvariablen (Vorlage)
# Kopiere diese Datei nach .env und trage deine echten Werte ein.
# .env wird von Git ignoriert und niemals hochgeladen.

DISCORD_TOKEN=dein_bot_token_hier
OWNER_ID=deine_discord_user_id
LOG_LEVEL=INFO

# Optional: Agnes AI für Pet-Bilder
AGNES_API_KEY=
AGNES_API_URL=https://apihub.agnes-ai.com/v1/images/generations
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_IMAGE_SIZE=1024x1024
AGNES_REQUEST_TIMEOUT=120
